{
  "name": "asciiart",
  "version": "1.0.0",
  "description": "A fully responsive, customizable HTML/CSS theme inspired by the charm of 7-bit ASCII art.",
  "type": "module",
  "main": "dist/js/asciiart.min.js",
  "module": "dist/js/asciiart.esm.min.js",
  "exports": {
    ".": {
      "import": "./dist/js/asciiart.esm.min.js",
      "require": "./dist/js/asciiart.min.js"
    }
  },
  "scripts": {
    "build:scss": "sass src/scss/style.scss dist/css/style.css --style=compressed",
    "build:js": "node build.mjs",
    "watch:js": "chokidar \"src/js/**/*.js\" -c \"npm run build:js\"",
    "watch:scss": "sass  src/scss/style.scss dist/css/style.css --no-source-map --watch",
    "build": "npm run build:scss && npm run build:js",
    "serve": "live-server demo",
    "start": "npm-run-all --parallel watch:js watch:scss serve"
  },
  "author": "Dimitrios Desyllas <pcmagas@disroot.org>",
  "license": "MIT",
  "devDependencies": {
    "chokidar": "^5.0.0",
    "chokidar-cli": "^3.0.0",
    "esbuild": "^0.27.4",
    "less": "^4.2.0",
    "live-server": "^1.2.2",
    "npm-run-all": "^4.1.5",
    "sass": "^1.76.0"
  },
  "dependencies": {
    "gulp": "^5.0.1",
    "gulp-sass": "^6.0.1"
  }
}
