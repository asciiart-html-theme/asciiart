{
  "name": "@pc_magas/asciiart",
  "version": "1.3.1",
  "description": "A fully responsive, customizable HTML/CSS theme inspired by the charm of 7-bit ASCII art.",
  "type": "module",
  "main": "dist/js/asciiart.min.js",
  "module": "dist/js/asciiart.esm.min.js",
  "exports": {
    ".": {
      "import": "./dist/js/asciiart.esm.min.js",
      "require": "./dist/js/asciiart.min.js"
    }
  },
  "files": [
    "dist/js",
    "dist/css",
    "src/js",
    "src/scss",
    "LICENSE"
  ],
  "scripts": {
    "build": "gulp",
    "release": "gulp build_js_css",
    "start": "gulp watch"
  },
  "author": "Dimitrios Desyllas <pcmagas@disroot.org>",
  "license": "MIT",
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "esbuild": "^0.27.4",
    "fs-extra": "^11.3.4",
    "gulp": "^5.0.1",
    "gulp-data": "^1.3.1",
    "gulp-live-server": "^0.0.31",
    "gulp-nunjucks-render": "^2.2.3",
    "gulp-rename": "^2.1.0",
    "gulp-sass": "^6.0.1",
    "nunjucks": "^3.2.4",
    "sass": "^1.76.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pc_magas/asciiart.git"
  }
}
