<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%=title %></title>

  <!-- SCSS compiled CSS -->
  <link rel="stylesheet" href="css/style.css">
  <script type="application/javascript" src="./js/asciiart.min.js"></script>
  <%- script %>
</head>
<body class="sidebar-layout">
  <div id="sidebar" class="aside-wrapper-fullheight">
    <button class="button-close" data-control-element="#sidebar"></button>
    <header  class="banner">
        <pre>
  ___           _ _  ___       _   
 / _ \         (_|_)/ _ \     | |  
/ /_\ \___  ___ _ _/ /_\ \_ __| |_ 
|  _  / __|/ __| | |  _  | '__| __|
| | | \__ \ (__| | | | | | |  | |_ 
\_| |_/___/\___|_|_\_| |_/_|   \__|
    </pre>
    </header>
    <aside>
      <nav aria-label="Sidebar navigation">
        <%- sidebar-nav %>
      </nav>
    </aside>
    <footer>
      Copyright Dimitrios Desyllas
    </footer>
  </div>
  <div class="main-wrapper">
    <div class="nav-wrapper sticky-top">
        <div class="lead">
          <button role="button" 
            class="button-expand button-toggle" 
            data-control-element="#sidebar"
          ></button>
        </div>
        <%- include('../partials/main-nav') %>
    </div>

    <main>
        <%- content %> 
    </main>
  </div>
</body>
</html>